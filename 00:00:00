-- 3. LÓGICA DO CRONÔMETRO
--------------------------------------------------------------------------------

local tempoDecorrido = 0
local executando = false
local conexaoHeartbeat = nil
local LIMITE_MAXIMO_SEGUNDOS = 6039.99

local function atualizarTexto()
	if tempoDecorrido >= LIMITE_MAXIMO_SEGUNDOS then
		tempoDecorrido = LIMITE_MAXIMO_SEGUNDOS
		executando = false
		btnIniciar.Text = "INICIAR"
		if conexaoHeartbeat then
			conexaoHeartbeat:Disconnect()
			conexaoHeartbeat = nil
		end
	end

	local minutos = math.floor(tempoDecorrido / 60)
	local segundos = math.floor(tempoDecorrido % 60)
	local centesimos = math.floor((tempoDecorrido % 1) * 100)

	timeLabel.Text = string.format("%02d:%02d.%02d", minutos, segundos, centesimos)
end

btnIniciar.MouseButton1Click:Connect(function()
	if executando then
		executando = false
		btnIniciar.Text = "INICIAR" -- MAIÚSCULO
		if conexaoHeartbeat then
			conexaoHeartbeat:Disconnect()
			conexaoHeartbeat = nil
		end
	else
		executando = true
		btnIniciar.Text = "PAUSAR" -- MAIÚSCULO
		
		local tempoAnterior = os.clock()
		conexaoHeartbeat = RunService.Heartbeat:Connect(function()
			local tempoAtual = os.clock()
			local dt = tempoAtual - tempoAnterior
			tempoAnterior = tempoAtual
			
			tempoDecorrido = tempoDecorrido + dt
			atualizarTexto()
		end)
	end
end)

